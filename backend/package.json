{
  "name": "gym-backend",
  "version": "2.0.0",
  "description": "Express API for Gym Management System",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build": "tsc",
    "migrate": "sequelize-cli db:migrate",
    "migrate:undo": "sequelize-cli db:migrate:undo:all",
    "seed": "sequelize-cli db:seed:all",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src --fix"
  },
  "keywords": [
    "gym",
    "api",
    "express",
    "postgresql"
  ],
  "author": "Reddevil79",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "sequelize": "^6.35.1",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "redis": "^4.6.12",
    "socket.io": "^4.7.2",
    "jsonwebtoken": "^9.1.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "axios": "^1.6.2",
    "stripe": "^13.11.0",
    "@sendgrid/mail": "^7.7.0",
    "twilio": "^4.6.0",
    "aws-sdk": "^2.1568.0",
    "multer": "^1.4.5-lts.1",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "compression": "^1.7.4",
    "express-rate-limit": "^7.1.5",
    "node-cron": "^3.0.3",
    "uuid": "^9.0.1",
    "pino": "^8.17.2",
    "pino-http": "^8.6.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "eslint": "^8.54.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "@types/jest": "^29.5.8",
    "sequelize-cli": "^6.6.2",
    "typescript": "^5.3.3"
  }
}
